---
import Layout from "../layouts/Layout.astro";
---

<Layout title="BetterVars">
	<main
		style="min-height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--color-bg);"
	>
		<div
			style="background: var(--color-bg-card); color: var(--color-text); padding: var(--space-md); border-radius: 12px; max-width: 32rem;"
		>
			<h1 class="text-heading-xl" style="font-size: var(--font-heading-xl); color: var(--color-primary); margin: 0 0 var(--space-sm);">
				BetterVars is live
			</h1>
			<p class="text-body-base" style="color: var(--color-text-muted); margin: 0;">
				This heading and box are styled entirely from bettervars/*.json, resolved through the codegen script into src/styles/bettervars.css.
			</p>
		</div>
	</main>
</Layout>
